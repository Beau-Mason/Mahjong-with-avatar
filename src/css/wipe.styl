#wipe
    position: fixed          // 盤面のスケールに影響されず画面隅に固定 = 枠の外
    right: 16px
    bottom: 16px
    width: 180px
    height: 135px
    z-index: 10
    border-radius: 8px
    overflow: hidden
    border: 3px solid rgba(255,255,255,0.6)
    box-shadow: 0 4px 16px rgba(0,0,0,0.6)
    background: #000
    transition: border-color 0.15s
    &.hide
        display: none
    video
        width: 100%
        height: 100%
        object-fit: cover
        transform: scaleX(-1)    // 鏡像（自分から見た自然な向き）
    // avatar条件: VRMを描くcanvasを枠いっぱいに敷く（videoは解析専用で非表示）
    &.avatar
        background: linear-gradient(160deg, #2a3550, #161b2c)
        .avatar-canvas
            width: 100%
            height: 100%
            display: block
    .bubble
        position: absolute
        left: 50%
        top: 8px
        transform: translateX(-50%) scale(0.6)
        opacity: 0
        padding: 4px 10px
        border-radius: 12px
        background: rgba(0,0,0,0.85)
        color: white
        font-family: text-font
        white-space: nowrap
        transition: opacity 0.15s, transform 0.15s
        &.show
            opacity: 1
            transform: translateX(-50%) scale(1)
    &.houju                       // 放銃: 赤フラッシュ
        border-color: #f00
        animation: wipe-flash 0.35s steps(1) 3
    &.tsumora                     // 被ツモ: オレンジ
        border-color: #fa0
    &.win                         // 自分の和了: シアン
        border-color: #0ff

@keyframes wipe-flash
    0%
        border-color: #f00
    50%
        border-color: transparent

// 実験(avatar/video)条件かつ十分広い画面では、盤面(800px)を左に寄せ、
// 空いた右カラムいっぱいにワイプを拡大する。
@media screen and (min-width: 1100px)
    html.wipe-avatar
    html.wipe-video
        body.board > #board
            margin-left: 24px       // 左端に少し余白
            margin-right: 0
        #wipe
            left: 840px             // 24(左余白) + 800(盤面) + 16(間隔)
            right: 16px
            top: 16px
            bottom: 16px
            width: auto             // 上下左右の固定で右カラムを満たす
            height: auto
